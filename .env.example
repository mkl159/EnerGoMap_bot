# 🔑 Configuration d'EnerGoMap_bot
# Copiez ce fichier vers `.env` puis remplissez les valeurs.
#   cp .env.example .env
#
# Token obtenu auprès de @BotFather sur Telegram (/newbot).
# ⚠️ Ne partagez JAMAIS ce token et ne le commitez pas (.env est gitignoré).
TELEGRAM_BOT_TOKEN=123456789:VOTRE_TOKEN_ICI

# Optionnel : chemin de la base SQLite (par défaut : energomap.sqlite3)
# DB_PATH=energomap.sqlite3
